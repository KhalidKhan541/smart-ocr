# SmartOCR.ai — Environment Variables
# Copy this file to .env and fill in values for local development.

# Cloudflare Pages environment
ENVIRONMENT=development

# CORS origin for the analytics API (use https://smartocr.ai in production)
CORS_ORIGIN=http://localhost:5173

# Vite dev server port (optional, defaults to 5173)
VITE_PORT=5173
